<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FinWise.MauiApp.Views.FinancialAssistantPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:sfChat="clr-namespace:Syncfusion.Maui.Chat;assembly=Syncfusion.Maui.Chat"
    xmlns:viewmodels="clr-namespace:FinWise.MauiApp.ViewModels"
    xmlns:views="clr-namespace:FinWise.MauiApp.Views.CustomViews.Views"
    Title="{Binding Title}"
    x:DataType="viewmodels:FinancialAssistantViewModel">


    <Grid RowDefinitions="0.15*,Auto,0.85*" RowSpacing="0">

        <!--  Token Usage Summary Panel  -->
        <Border
            Grid.Row="0"
            Margin="0"
            Padding="15,10"
            BackgroundColor="{AppThemeBinding Light=#F5F5F5,
                                              Dark=#2D2D2D}">
            <VerticalStackLayout Spacing="6">
                <HorizontalStackLayout Spacing="8">
                    <Label
                        FontSize="12"
                        Text="Token mode:"
                        TextColor="{AppThemeBinding Light=#333333,
                                                    Dark=#EEEEEE}"
                        VerticalOptions="Center" />
                    <Picker
                        ItemsSource="{Binding TokenModes}"
                        SelectedItem="{Binding SelectedTokenMode}"
                        WidthRequest="130" />
                </HorizontalStackLayout>
                <Grid
                    ColumnDefinitions="*,Auto,Auto,Auto"
                    ColumnSpacing="10"
                    RowDefinitions="0.2*,0.8*">
                <Label
                    FontAttributes="Bold"
                    FontSize="14"
                    Text="Token Usage Summary"
                    TextColor="{AppThemeBinding Light=#333333,
                                                Dark=#EEEEEE}" />
                <ScrollView Grid.Row="1" Grid.Column="0">
                    <VerticalStackLayout
                        Grid.Row="1"
                        Grid.Column="0"
                        Spacing="2">
                        <Label
                            FontSize="11"
                            LineBreakMode="WordWrap"
                            Text="{Binding TokenSummary}"
                            TextColor="{AppThemeBinding Light=#666666,
                                                        Dark=#CCCCCC}" />
                    </VerticalStackLayout>
                </ScrollView>
                <VerticalStackLayout
                    Grid.Row="1"
                    Grid.Column="1"
                    Spacing="5"
                    VerticalOptions="Start">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        HorizontalOptions="End"
                        Text="{Binding RoutedAgent, StringFormat='Agent: {0}'}"
                        TextColor="{StaticResource Primary}" />
                    <Label
                        FontSize="11"
                        HorizontalOptions="End"
                        Text="{Binding RoutingConfidence, StringFormat='Confidence: {0:P0}'}"
                        TextColor="{AppThemeBinding Light=#666666,
                                                    Dark=#CCCCCC}" />
                </VerticalStackLayout>
                <!--  More Options Button  -->
                <Button
                    Grid.Row="1"
                    Grid.Column="2"
                    Margin="4"
                    Padding="0"
                    BackgroundColor="Transparent"
                    Command="{Binding ShowTelemetryForMessageCommand}"
                    CommandParameter="{Binding LastAssistantTextMessage}"
                    FontSize="18"
                    HeightRequest="44"
                    Text="📊"
                    TextColor="{AppThemeBinding Light=#0D47A1,
                                                Dark=#BBDEFB}"
                    ToolTipProperties.Text="View Last Message Telemetry"
                    WidthRequest="44" />
                <Button
                    Grid.Row="1"
                    Grid.Column="3"
                    BackgroundColor="{AppThemeBinding Light=#F0F0F0,
                                                      Dark=#3D3D3D}"
                    Clicked="OnMoreOptionsClicked"
                    CornerRadius="20"
                    FontSize="24"
                    HeightRequest="44"
                    Text="⋮"
                    TextColor="{AppThemeBinding Light=Black,
                                                Dark=White}"
                    WidthRequest="44" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!--  Telemetry Info Card (Collapsible)  -->
        <Border
            Grid.Row="1"
            Margin="8,4,8,4"
            Padding="12"
            BackgroundColor="{AppThemeBinding Light=#F0F8FF,
                                              Dark=#0D1B2A}"
            Stroke="{AppThemeBinding Light=#1E90FF,
                                     Dark=#4A90E2}"
            StrokeThickness="1">
            <VerticalStackLayout Spacing="6">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Label
                        Grid.Column="0"
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="ℹ️ Token Telemetry Explained"
                        TextColor="{AppThemeBinding Light=#0D3D9E,
                                                    Dark=#87CEEB}" />
                    <Button
                        x:Name="telemetryInfoToggle"
                        Grid.Column="2"
                        Margin="0"
                        Padding="2,0"
                        BackgroundColor="Transparent"
                        Clicked="OnTelemetryInfoToggle"
                        FontSize="14"
                        HeightRequest="32"
                        Text="▼"
                        TextColor="{AppThemeBinding Light=#0D3D9E,
                                                    Dark=#87CEEB}"
                        WidthRequest="32" />
                </Grid>

                <!--  Info Content (Collapsible)  -->
                <VerticalStackLayout x:Name="telemetryInfoContent" Spacing="6">

                    <Label
                        FontSize="10"
                        LineBreakMode="WordWrap"
                        Text="Token telemetry shows how many 'tokens' (text chunks) your request used across the AI processing pipeline."
                        TextColor="{AppThemeBinding Light=#333333,
                                                    Dark=#DDDDDD}" />

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E0E0E0, Dark=#444444}" />

                    <!--  Three Types Explanation  -->
                    <VerticalStackLayout Spacing="4">
                        <Label
                            FontAttributes="Bold"
                            FontSize="10"
                            Text="Three Types of Token Counts:"
                            TextColor="{AppThemeBinding Light=#0D3D9E,
                                                        Dark=#87CEEB}" />

                        <VerticalStackLayout Margin="8,0,0,0" Spacing="3">
                            <Label
                                FontAttributes="Bold"
                                FontSize="9"
                                Text="✓ EXACT"
                                TextColor="{AppThemeBinding Light=#1B5E20,
                                                            Dark=#66BB6A}" />
                            <Label
                                FontSize="9"
                                LineBreakMode="WordWrap"
                                Text="From the AI provider (e.g., Azure OpenAI). Highest accuracy. Not always available."
                                TextColor="{AppThemeBinding Light=#333333,
                                                            Dark=#CCCCCC}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Margin="8,0,0,0" Spacing="3">
                            <Label
                                FontAttributes="Bold"
                                FontSize="9"
                                Text="📊 ESTIMATED"
                                TextColor="{AppThemeBinding Light=#F57F17,
                                                            Dark=#FFC107}" />
                            <Label
                                FontSize="9"
                                LineBreakMode="WordWrap"
                                Text="Calculated locally using: text length ÷ 4. Always available but less accurate (~±20%)."
                                TextColor="{AppThemeBinding Light=#333333,
                                                            Dark=#CCCCCC}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Margin="8,0,0,0" Spacing="3">
                            <Label
                                FontAttributes="Bold"
                                FontSize="9"
                                Text="🎯 MEASURED"
                                TextColor="{AppThemeBinding Light=#0D3D9E,
                                                            Dark=#87CEEB}" />
                            <Label
                                FontSize="9"
                                LineBreakMode="WordWrap"
                                Text="Smart choice: uses EXACT if available, falls back to ESTIMATED if needed. Best of both worlds."
                                TextColor="{AppThemeBinding Light=#333333,
                                                            Dark=#CCCCCC}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E0E0E0, Dark=#444444}" />

                    <!--  Where Tokens Come From  -->
                    <VerticalStackLayout Spacing="3">
                        <Label
                            FontAttributes="Bold"
                            FontSize="10"
                            Text="Three Tiers:"
                            TextColor="{AppThemeBinding Light=#0D3D9E,
                                                        Dark=#87CEEB}" />

                        <VerticalStackLayout Margin="8,0,0,0" Spacing="2">
                            <Label
                                FontSize="9"
                                LineBreakMode="WordWrap"
                                Text="🔹 SUPERVISOR: Tokens used by the router agent"
                                TextColor="{AppThemeBinding Light=#333333,
                                                            Dark=#CCCCCC}" />
                            <Label
                                FontSize="9"
                                LineBreakMode="WordWrap"
                                Text="🔹 DOWNSTREAM: Tokens used by specialist agents"
                                TextColor="{AppThemeBinding Light=#333333,
                                                            Dark=#CCCCCC}" />
                            <Label
                                FontSize="9"
                                LineBreakMode="WordWrap"
                                Text="🔹 TOTAL: Sum of supervisor + downstream"
                                TextColor="{AppThemeBinding Light=#333333,
                                                            Dark=#CCCCCC}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E0E0E0, Dark=#444444}" />

                    <!--  Why It Matters  -->
                    <VerticalStackLayout Spacing="3">
                        <Label
                            FontAttributes="Bold"
                            FontSize="10"
                            Text="Why It Matters:"
                            TextColor="{AppThemeBinding Light=#0D3D9E,
                                                        Dark=#87CEEB}" />

                        <VerticalStackLayout Margin="8,0,0,0" Spacing="2">
                            <Label
                                FontSize="9"
                                LineBreakMode="WordWrap"
                                Text="💰 Tokens = Cost: More tokens = higher API costs"
                                TextColor="{AppThemeBinding Light=#333333,
                                                            Dark=#CCCCCC}" />
                            <Label
                                FontSize="9"
                                LineBreakMode="WordWrap"
                                Text="🎯 Accuracy: EXACT (✓) is more trustworthy than ESTIMATED (⚠️)"
                                TextColor="{AppThemeBinding Light=#333333,
                                                            Dark=#CCCCCC}" />
                            <Label
                                FontSize="9"
                                LineBreakMode="WordWrap"
                                Text="🔍 Debugging: Identify which agent used the most tokens"
                                TextColor="{AppThemeBinding Light=#333333,
                                                            Dark=#CCCCCC}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <Label
                        FontAttributes="Italic"
                        FontSize="8"
                        LineBreakMode="WordWrap"
                        Text="💡 Tip: Tap the 📊 button in the summary bar to see detailed token breakdown in a bottom sheet."
                        TextColor="{AppThemeBinding Light=#666666,
                                                    Dark=#999999}" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Border>

        <!--  Telemetry Details Panel (Collapsible)  -->
        <Border
            Grid.Row="2"
            Margin="0"
            Padding="0"
            BackgroundColor="{AppThemeBinding Light=#EFEFEF,
                                              Dark=#1F1F1F}"
            IsVisible="{Binding LastEnhancedResponse, Converter={StaticResource InvertedBoolConverter}}">
            <views:TelemetryDetailView BindingContext="{Binding}" />
        </Border>

        <!--  Syncfusion Chat Control  -->
        <sfChat:SfChat
            x:Name="ChatControl"
            Grid.Row="2"
            CurrentUser="{Binding CurrentUser}"
            MessageDoubleTapped="ChatControl_MessageDoubleTapped"
            Messages="{Binding ChatMessages, Mode=OneWay}"
            SendMessageCommand="{Binding SendChatMessageCommand}"
            ShowDeliveryState="True"
            ShowIncomingMessageAvatar="True"
            ShowOutgoingMessageAvatar="True"
            ShowTypingIndicator="{Binding IsProcessing}"
            SuggestionItemSelected="ChatControl_SuggestionItemSelected"
            Suggestions="{Binding ChatSuggestions}" />

        <!--  Loading Overlay  -->
        <Grid
            Grid.Row="0"
            Grid.RowSpan="3"
            BackgroundColor="#80000000"
            IsVisible="{Binding IsProcessing}">
            <ActivityIndicator
                HeightRequest="50"
                IsRunning="{Binding IsProcessing}"
                WidthRequest="50"
                Color="{StaticResource Primary}" />
        </Grid>
        <views:TelemetryDetailsPage
            x:Name="telemetryDetailsSheet"
            Grid.Row="2"
            AllowedState="HalfExpanded"
            BindingContext="{Binding SelectedTelemetry}"
            ContentPadding="15"
            CornerRadius="25, 25, 0,0"
            HalfExpandedRatio="{OnIdiom Phone=0.65,
                                        Default=0.9}"
            IsModal="True"
            IsOpen="{Binding IsTelemetryDetailsVisible}" />
    </Grid>

</ContentPage>
