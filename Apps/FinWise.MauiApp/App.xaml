<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="FinWise.MauiApp.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:FinWise.MauiApp.Converters"
    xmlns:local="clr-namespace:FinWise.MauiApp">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!--  Add converters  -->
            <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
            <converters:BoolToMarginConverter x:Key="BoolToMarginConverter" />
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <converters:BoolToFontAttributeConverter x:Key="BoolToFontAttributeConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
