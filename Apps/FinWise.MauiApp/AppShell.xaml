<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FinWise.MauiApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FinWise.MauiApp"
    xmlns:views="clr-namespace:FinWise.MauiApp.Views"
    Title="FinWise.MauiApp">

    <TabBar>
        <ShellContent
            Title="Main"
            Route="main"
            ContentTemplate="{DataTemplate views:MainPage}"
            Icon="iconblank.png" />
        <ShellContent
            Title="💬 AI Assistant"
            Route="llmrouting"
            ContentTemplate="{DataTemplate views:FinancialAssistantPage}"
            Icon="iconblank.png" />
        <ShellContent
            Title="🎯 Direct Routing"
            Route="directrouting"
            ContentTemplate="{DataTemplate views:DirectAgentRoutingPage}"
            Icon="iconblank.png" />
    </TabBar>
</Shell>
